# Copy to `.env` (gitignored) and fill in. Huly authenticates with an
# ACCOUNT EMAIL + PASSWORD — there is no API token.
HULY_API_USER=you@example.com        # account email
HULY_PASSWORD=your-account-password  # account password (never commit)
HULY_WORKSPACE=acme-dev              # logical workspace name
HULY_FRONT_URL=https://huly.app      # optional; defaults to https://huly.app
