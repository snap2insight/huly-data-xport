# Node deps
node_modules/
# TypeScript build output
packages/*/dist/
**/*.tsbuildinfo
# Python
__pycache__/
*.pyc
.venv/
# Build artifacts — regenerable; per content/example dir
_build/
docs/_build/
examples/*/_build/
