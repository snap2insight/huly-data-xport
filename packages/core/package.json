{
  "name": "@huly-data-xport/core",
  "version": "0.1.1",
  "description": "Reusable, surface-agnostic core for importing/exporting data with Huly: a typed ImportWorkspace model, universal-format emit/parse/validate, and an import/export engine built entirely on published @hcengineering/* packages (no Docker).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "import": "./dist/model/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "node --test dist/engine/ dist/format/ dist/model/"
  },
  "dependencies": {
    "@hcengineering/account-client": "0.7.423",
    "@hcengineering/api-client": "0.7.423",
    "@hcengineering/attachment": "^0.7.423",
    "@hcengineering/card": "^0.7.423",
    "@hcengineering/chunter": "^0.7.423",
    "@hcengineering/collaboration": "^0.7.423",
    "@hcengineering/contact": "^0.7.423",
    "@hcengineering/core": "0.7.423",
    "@hcengineering/document": "^0.7.0",
    "@hcengineering/hr": "^0.7.423",
    "@hcengineering/rank": "^0.7.423",
    "@hcengineering/tags": "0.7.423",
    "@hcengineering/task": "^0.7.423",
    "@hcengineering/templates": "^0.7.423",
    "@hcengineering/text": "^0.7.423",
    "@hcengineering/text-markdown": "^0.7.423",
    "@hcengineering/time": "^0.7.423",
    "@hcengineering/tracker": "0.7.423",
    "@hcengineering/view": "^0.7.423",
    "ws": "^8.18.0",
    "yaml": "^2.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
